# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Groq AI (FREE — no billing required) ─────────────────────────────────────
# Sign up at console.groq.com → API Keys → Create new key
# Free tier: 14,400 requests/day, 30 req/min — more than enough
GROQ_API_KEY=gsk_your_groq_key_here

# ── Resend (optional — auto-reply emails) ─────────────────────────────────────
# Free tier at resend.com: 100 emails/day
RESEND_API_KEY=re_your_resend_key_here

# ── Admin password ────────────────────────────────────────────────────────────
# Change this to something only you know
NEXT_PUBLIC_ADMIN_PASS=change_me_to_something_secret

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
